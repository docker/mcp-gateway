{
  "url": "https://registry.modelcontextprotocol.io/v0/servers/io.github.abhishekbhakat%2Fairflow-mcp-server/versions/0.9.0",
  "serverName": "io-github-abhishekbhakat-airflow-mcp-server",
  "registryName": "io.github.abhishekbhakat/airflow-mcp-server",
  "version": "0.9.0",
  "canTest": false,
  "skipReason": "AUTH_TOKEN is a required secret (JWT token) that must be dynamically obtained from a running Airflow instance. Even with a local Airflow backing service, the JWT token cannot be statically pre-configured and requires an authentication flow against the running instance to generate.",
  "config": {
    "AIRFLOW_BASE_URL": "http://host.docker.internal:8080"
  },
  "services": [
    {
      "name": "airflow",
      "image": "apache/airflow:2.10.4",
      "ports": [
        "8080:8080"
      ],
      "env": {
        "AIRFLOW__CORE__EXECUTOR": "SequentialExecutor",
        "AIRFLOW__CORE__LOAD_EXAMPLES": "true",
        "_AIRFLOW_DB_MIGRATE": "true",
        "_AIRFLOW_WWW_USER_CREATE": "true",
        "_AIRFLOW_WWW_USER_USERNAME": "admin",
        "_AIRFLOW_WWW_USER_PASSWORD": "admin"
      }
    }
  ]
}